# Estheva Studio — Environment Variables
# Copy this file to .env and fill in real values if needed.
# For local development, no environment variables are required.

# Optional: Set the port for the dev server (default: 5173)
# VITE_PORT=5173

# Optional: WhatsApp phone number for the floating button and booking links
# VITE_WHATSAPP_NUMBER=91XXXXXXXXXX

# Optional: Google Maps embed URL for the contact page map placeholder
# VITE_MAPS_EMBED_URL=https://www.google.com/maps/embed?...
